meta {
  name: Create Mission
  type: http
  seq: 1
}

post {
  url: {{base_url}}/missions
  body: json
  auth: none
}

body:json {
  {
    "title": "Refactor auth module",
    "description": "Clean up the legacy auth middleware",
    "xp_reward": 150,
    "coin_reward": 50
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("mission_id", res.body.id);
  }
}

assert {
  res.status: eq 201
  res.body.title: eq Refactor auth module
  res.body.is_active: eq true
}
