meta {
  name: Complete Mission
  type: http
  seq: 4
}

post {
  url: {{base_url}}/missions/{{mission_id}}/complete
  body: json
  auth: none
}

body:json {
  {
    "user_id": "{{user_id}}"
  }
}

assert {
  res.status: eq 201
  res.body.user_id: eq {{user_id}}
  res.body.mission_id: eq {{mission_id}}
}
