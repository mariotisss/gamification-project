    {
      "type": "text", "id": "ev_code_h",
      "x": 620, "y": 1325, "width": 850, "height": 22,
      "text": "MissionService.complete_mission(user_id, mission_id)",
      "originalText": "MissionService.complete_mission(user_id, mission_id)",
      "fontSize": 14, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fef3c7", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500042, "version": 1, "versionNonce": 500043,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "ev_code_l1",
      "x": 620, "y": 1360, "width": 850, "height": 22,
      "text": "1.  user = self._user_repo.get_by_id(user_id)",
      "originalText": "1.  user = self._user_repo.get_by_id(user_id)",
      "fontSize": 13, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500044, "version": 1, "versionNonce": 500045,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "ev_code_l1b",
      "x": 645, "y": 1383, "width": 850, "height": 22,
      "text": "if None  →  raise EntityNotFoundError  →  HTTP 404",
      "originalText": "if None  →  raise EntityNotFoundError  →  HTTP 404",
      "fontSize": 11, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fca5a5", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500046, "version": 1, "versionNonce": 500047,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "ev_code_l2",
      "x": 620, "y": 1414, "width": 850, "height": 22,
      "text": "2.  mission = self._mission_repo.get_by_id(mission_id)",
      "originalText": "2.  mission = self._mission_repo.get_by_id(mission_id)",
      "fontSize": 13, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500048, "version": 1, "versionNonce": 500049,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "ev_code_l3",
      "x": 620, "y": 1444, "width": 850, "height": 22,
      "text": "3.  if any(c.mission_id == mission_id for c in user_completions):",
      "originalText": "3.  if any(c.mission_id == mission_id for c in user_completions):",
      "fontSize": 13, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500050, "version": 1, "versionNonce": 500051,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "ev_code_l3b",
      "x": 645, "y": 1467, "width": 850, "height": 22,
      "text": "raise MissionAlreadyCompletedError  →  HTTP 409",
      "originalText": "raise MissionAlreadyCompletedError  →  HTTP 409",
      "fontSize": 11, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fca5a5", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
