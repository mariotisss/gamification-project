    },
    {
      "type": "text", "id": "ev_code_l4",
      "x": 620, "y": 1498, "width": 850, "height": 22,
      "text": "4.  user.add_xp(mission.xp_reward)        # level = floor(xp/100) + 1",
      "originalText": "4.  user.add_xp(mission.xp_reward)        # level = floor(xp/100) + 1",
      "fontSize": 13, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
